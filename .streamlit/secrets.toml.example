# 複製本檔為 .streamlit/secrets.toml 並填入真實值(secrets.toml 已被 .gitignore,不會進版控)。
# Streamlit Cloud 部署:不要上傳 secrets.toml,改在 App settings → Secrets 逐行貼入。

# ── Gemini(每日戰略報告 / 趨勢雷達 / 台股觀察)──────────────────────
GEMINI_API_KEY = "your-gemini-api-key-here"

# ── NAS 中繼站(抓 MoneyDJ ETF 成分股,繞過境外 IP 封鎖)────────────
# 新格式(推薦):單行 URL
PROXY_URL = "http://你的帳號:你的密碼@yourname.synology.me:3128"

# 舊格式(向下相容,與上面二選一,不要同時放):
# [proxy]
# username = "你的帳號"
# password = "你的密碼"
# endpoint = "yourname.synology.me:3128"
